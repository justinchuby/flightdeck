{
  "name": "@flightdeck/server",
  "version": "0.4.3",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cd ../shared && node -e \"try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch{}\" && npm run build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@flightdeck/shared": "*",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
