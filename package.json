{
  "name": "ai-crew",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ai-crew": "./bin/ai-crew.mjs"
  },
  "workspaces": [
    "packages/server",
    "packages/web",
    "packages/docs"
  ],
  "scripts": {
    "start": "node bin/ai-crew.mjs",
    "dev": "concurrently \"npm run dev --workspace=packages/server\" \"npm run dev --workspace=packages/web\"",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/web",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test:e2e": "npm run test:e2e --workspace=packages/web",
    "test": "npm run test --workspace=packages/server",
    "docs:dev": "npm run dev --workspace=packages/docs",
    "docs:build": "npm run build --workspace=packages/docs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
