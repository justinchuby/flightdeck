{
  "name": "@flightdeck-ai/flightdeck",
  "version": "0.4.1",
  "description": "Flightdeck - AI crew management platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/justinchuby/flightdeck.git"
  },
  "bugs": {
    "url": "https://github.com/justinchuby/flightdeck/issues"
  },
  "homepage": "https://github.com/justinchuby/flightdeck#readme",
  "type": "module",
  "bin": {
    "flightdeck": "./bin/flightdeck.mjs"
  },
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web",
    "packages/docs"
  ],
  "files": [
    "bin/",
    "packages/shared/dist/",
    "packages/server/dist/",
    "!packages/server/dist/__tests__/",
    "!**/*.map",
    "packages/server/drizzle/",
    "packages/web/dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node bin/flightdeck.mjs",
    "prepublishOnly": "npm run build",
    "predev": "npm run build:shared",
    "build:shared": "cd packages/shared && rm -f tsconfig.tsbuildinfo && npm run build",
    "dev": "node scripts/dev.mjs",
    "predev:server": "npm run build:shared",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/server && npm run build --workspace=packages/web",
    "lint": "eslint packages/*/src/",
    "test:e2e": "npm run test:e2e --workspace=packages/web",
    "test": "npm run test --workspace=packages/server",
    "docs:dev": "npm run dev --workspace=packages/docs",
    "docs:build": "npm run build --workspace=packages/docs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "helmet": "^8.1.0",
    "pino": "^9.14.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
