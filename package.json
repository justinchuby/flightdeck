{
  "name": "ai-crew",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server & npm run dev --workspace=packages/web",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:web": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/web",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "test:e2e": "npm run test:e2e --workspace=packages/web",
    "test": "npm run test --workspace=packages/server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
